<UserControl x:Class="PastMediaPlayer_Project.MediaControl.FolderTreeCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PastMediaPlayer_Project.MediaControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="24"></RowDefinition>
            <RowDefinition Height="276"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Name="SearchBox" VerticalContentAlignment="Center"
                 TextChanged="SearchBox_TextChanged"/>

        <TreeView Grid.Row="1" Name="TreeViewRoot">
            
        </TreeView>

        <GridSplitter Grid.Row="1" Height="2" 
                      VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                      Background="Black"/>

        <TextBox Grid.Row="2"/>
        <ScrollViewer Grid.Row="3" Background="White"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl Name="TagListView" Background="White">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Display}"
                                Margin="0,0,6,6" Padding="8,2,8,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
